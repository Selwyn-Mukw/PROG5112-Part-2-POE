<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Chatbot"
        Height="1000"
        Width="1200"
        MinWidth="1200"
        Background="#1E1E1E">

    <Grid Margin="10">

        <!-- ROWS -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <StackPanel Grid.Row="0">

            <!-- ASCII LOGO -->
            <Border Background="#111111"
                    CornerRadius="10"
                    Padding="15"
                    BorderBrush="Lime"
                    BorderThickness="1"
                    Margin="0,0,0,10">

                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">

                    <TextBox x:Name="AsciiArt"
                             FontFamily="Consolas"
                             FontSize="7"
                             Foreground="Lime"
                             Background="Transparent"
                             BorderThickness="0"
                             IsReadOnly="True"
                             IsTabStop="False"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             HorizontalAlignment="Center"/>
                </ScrollViewer>
            </Border>

            <!-- BOT TITLE -->
            <TextBlock Text=" [*********************]  |  ORI THE CYBER BOT  |  [*********************]"
                       FontFamily="Consolas"
                       Foreground="White"
                       FontSize="16"
                       TextAlignment="Center"
                       Margin="0,5,0,10"/>
        </StackPanel>

        <!-- ================= CHAT HISTORY AREA ================= -->
        <Border Grid.Row="1"
                Background="#252526"
                CornerRadius="10"
                Padding="10"
                Margin="0,10,0,10"
                BorderBrush="Lime"
                BorderThickness="1">

            <!-- Scrollable Read-Only Chat Area -->
            <RichTextBox x:Name="ChatHistory"
                         Background="#252526"
                         Foreground="White"
                         FontFamily="Consolas"
                         FontSize="15"
                         IsReadOnly="True"
                         BorderThickness="0"
                         VerticalScrollBarVisibility="Auto"/>
        </Border>

        <!-- ================= INPUT AREA ================= -->
        <Grid Grid.Row="2"
              Margin="0,5,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="140"/>
            </Grid.ColumnDefinitions>

            <!-- USER INPUT -->
            <Border Grid.Column="0"
                    Background="#3C3C3C"
                    CornerRadius="8"
                    BorderBrush="Lime"
                    BorderThickness="1"
                    Margin="0,0,10,0">

                <TextBox x:Name="UserInput"
                         FontSize="16"
                         FontFamily="Consolas"
                         Foreground="White"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="10"
                         CaretBrush="Lime"
                         VerticalContentAlignment="Center"
                         Height="45"/>
            </Border>

            <!-- SEND BUTTON -->
            <Button x:Name="SendButton"
                    Grid.Column="1"
                    Content="SEND"
                    FontSize="16"
                    FontWeight="Bold"
                    FontFamily="Consolas"
                    Background="Lime"
                    Foreground="Black"
                    BorderThickness="0"
                    Height="45"
                    Cursor="Hand"
                    Click="SendButton_Click"/>
        </Grid>

    </Grid>
 
</Window>